DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=sky-breaker.ru,www.sky-breaker.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://sky-breaker.ru,https://www.sky-breaker.ru
DATABASE_URL=postgresql://skybreaker:skybreaker@localhost:5432/skybreaker
TRANSCRIPTION_API_TOKEN=change-me
TRANSCRIPTION_DJANGO_API_BASE=http://localhost:8000/api/transcription
TRANSCRIPTION_DISCOVERY_RECORDINGS_DIR=D:\Meetings
TRANSCRIPTION_DISCOVERY_DB=services\transcription_discovery\var\discovery.sqlite3
TRANSCRIPTION_DISCOVERY_SCAN_INTERVAL_SECONDS=60
TRANSCRIPTION_DISCOVERY_FILE_STABLE_SECONDS=300
TRANSCRIPTION_DISCOVERY_EXTENSIONS=.mp3,.wav,.m4a,.mp4,.webm
TRANSCRIPTION_SPEACHES_STUB=True
TRANSCRIPTION_SPEACHES_BASE_URL=http://localhost:8008
TRANSCRIPTION_SPEACHES_MODEL=whisper-large-v3
TRANSCRIPTION_SPEACHES_LANGUAGE=ru
