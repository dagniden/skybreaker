    <bpmn:sequenceFlow id="Flow_1vksqp1" name="самовывоз" sourceRef="Gateway_0odrosp" targetRef="Activity_0easlk8">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=delivery = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0lb6xig" name="доставка" sourceRef="Gateway_0odrosp" targetRef="Gateway_1cs5mjh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=delivery = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Activity_1ekf2qg" name="Подготовить заказ для курьера">
