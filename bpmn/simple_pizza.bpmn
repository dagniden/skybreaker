    <bpmn:sequenceFlow id="Flow_0w9yg4i" sourceRef="Activity_0easlk8" targetRef="Event_1l9xgnq" />
    <bpmn:endEvent id="Event_1nnlhkk" name="Заказ для курьера подготовлен">
