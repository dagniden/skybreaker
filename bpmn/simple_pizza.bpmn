      <bpmn:incoming>Flow_0lb6xig</bpmn:incoming>
      <bpmn:outgoing>Flow_02kbiz5</bpmn:outgoing>
      <bpmn:outgoing>Flow_0e2n2af</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_02kbiz5" name="да" sourceRef="Gateway_1cs5mjh" targetRef="Activity_1ekf2qg">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=distanceKm &lt;= 10</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_01hqmng" name="Отмена заказа">
