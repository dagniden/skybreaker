      <bpmn:incoming>Flow_0w26jve</bpmn:incoming>
      <bpmn:outgoing>Flow_0j2kmgd</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:textAnnotation id="TextAnnotation_14l8qgq">
      <bpmn:text>слишком далеко везти</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1173rwe" associationDirection="None" sourceRef="Event_01hqmng" targetRef="TextAnnotation_14l8qgq" />
