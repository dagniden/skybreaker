      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=distanceKm &gt; 10</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Activity_0easlk8" name="Подготовить заказ для самовывоза">
