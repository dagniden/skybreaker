  <bpmn:process id="Process_16ili12" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Заказ пиццы">
      <bpmn:documentation>Пример входного json:

{
  "customer": {
    "name": "Pavel",
    "vip": true
  },
  "order": {
    "delivery": true,
    "distanceKm": 7,
    "items": [
      {
        "name": "pepperoni",
        "quantity": 2,
        "price": 850
      },
      {
        "name": "cola",
        "quantity": 1,
        "price": 150
      }
    ]
  }
}</bpmn:documentation>
      <bpmn:outgoing>Flow_0w26jve</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_0lw5dop" name="Нужно подтверждение?" default="Flow_08yjgrl">
      <bpmn:incoming>Flow_0j2kmgd</bpmn:incoming>
      <bpmn:outgoing>Flow_0q79rux</bpmn:outgoing>
      <bpmn:outgoing>Flow_08yjgrl</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0w26jve" sourceRef="StartEvent_1" targetRef="Activity_10dqd5g" />
    <bpmn:sequenceFlow id="Flow_0q79rux" name="да" sourceRef="Gateway_0lw5dop" targetRef="Activity_0s91ar9">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=needsApproval</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_0odrosp" name="Доставка или самовывоз?" default="Flow_0lb6xig">
      <bpmn:incoming>Flow_08yjgrl</bpmn:incoming>
      <bpmn:incoming>Flow_1w7r15e</bpmn:incoming>
      <bpmn:outgoing>Flow_1vksqp1</bpmn:outgoing>
      <bpmn:outgoing>Flow_0lb6xig</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_08yjgrl" name="нет" sourceRef="Gateway_0lw5dop" targetRef="Gateway_0odrosp" />
    <bpmn:sequenceFlow id="Flow_1w7r15e" sourceRef="Activity_0s91ar9" targetRef="Gateway_0odrosp" />
    <bpmn:userTask id="Activity_0s91ar9" name="Подтвердить заказ">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0q79rux</bpmn:incoming>
      <bpmn:outgoing>Flow_1w7r15e</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1vksqp1" name="самовывоз" sourceRef="Gateway_0odrosp" targetRef="Activity_0easlk8">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=delivery = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0lb6xig" name="доставка" sourceRef="Gateway_0odrosp" targetRef="Gateway_1cs5mjh" />
    <bpmn:userTask id="Activity_1ekf2qg" name="Подготовить заказ для курьера">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_02kbiz5</bpmn:incoming>
      <bpmn:outgoing>Flow_1bqbffx</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1cs5mjh" name="Расстояние &#60;= 10км?" default="Flow_0e2n2af">
      <bpmn:incoming>Flow_0lb6xig</bpmn:incoming>
      <bpmn:outgoing>Flow_02kbiz5</bpmn:outgoing>
      <bpmn:outgoing>Flow_0e2n2af</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_02kbiz5" name="да" sourceRef="Gateway_1cs5mjh" targetRef="Activity_1ekf2qg">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=distanceKm &lt;= 10</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_01hqmng" name="Отмена заказа">
      <bpmn:incoming>Flow_0e2n2af</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0e2n2af" name="нет" sourceRef="Gateway_1cs5mjh" targetRef="Event_01hqmng" />
    <bpmn:userTask id="Activity_0easlk8" name="Подготовить заказ для самовывоза">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1vksqp1</bpmn:incoming>
      <bpmn:outgoing>Flow_0w9yg4i</bpmn:outgoing>
